DATABASE_URL=postgresql://postgres:
PORT=3100
SERVE_UI=false

# Claude (claude-local adapter)
# ANTHROPIC_API_KEY=

# --- Railway (authenticated + public, Postgres + S3) ---
# In Railway, set DATABASE_URL via reference: ${{Postgres.DATABASE_URL}}
# PAPERCLIP_DEPLOYMENT_MODE=authenticated
# PAPERCLIP_DEPLOYMENT_EXPOSURE=public
# PAPERCLIP_AUTH_PUBLIC_BASE_URL=https://your-app.up.railway.app
# BETTER_AUTH_SECRET=<generate: openssl rand -base64 32>
# PAPERCLIP_STORAGE_PROVIDER=s3
# PAPERCLIP_STORAGE_S3_BUCKET=your-bucket
# PAPERCLIP_STORAGE_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# PAPERCLIP_SECRETS_MASTER_KEY=<32-byte base64/hex, generate once and store securely>
